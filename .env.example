# Environment configuration for WARBIRD token
# ============================================

# Solana cluster: devnet | mainnet-beta
SOLANA_CLUSTER=devnet

# Path to your Solana wallet keypair JSON file
# Generate one with: solana-keygen new --outfile ./wallet.json
WALLET_PATH=./wallet.json

# Token config
TOKEN_NAME=WarBird
TOKEN_SYMBOL=WARBIRD
TOKEN_DECIMALS=9
TOKEN_SUPPLY=100000000

# Metadata URI (set after uploading metadata JSON)
TOKEN_METADATA_URI=
